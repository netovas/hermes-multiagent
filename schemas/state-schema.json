{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZethPhoenix Project State",
  "type": "object",
  "required": ["project_id", "division", "current_phase", "created_at"],
  "properties": {
    "project_id": {"type": "string"},
    "title": {"type": "string"},
    "stakeholder_request": {"type": "string"},
    "division": {"type": "string"},
    "current_phase": {"type": "string"},
    "current_role": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["active", "blocked", "paused", "completed", "cancelled"]},
    "agents_spawned": {"type": "array", "items": {"type": "string"}},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {"type": "string"},
          "produced_by": {"type": "string"},
          "version": {"type": "string"},
          "signed_off": {"type": "boolean"}
        }
      }
    },
    "handoff_log": {"type": "array"},
    "cross_division_consults": {"type": "array"},
    "fallback_events": {"type": "array"}
  }
}